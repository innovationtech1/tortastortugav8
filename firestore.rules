rules_version = '2';

// ═══════════════════════════════════════════════════════════
//  REGLAS DE FIRESTORE — Tortas Tortuga POS
//  Copia este contenido en:
//  Firebase Console → Firestore Database → Reglas → Publicar
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── PRODUCTOS ──
    // Lectura publica (el menu debe verse sin login)
    // Escritura: solo usuarios autenticados (admin)
    match /productos/{productoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── PEDIDOS ──
    // Crear: cualquiera puede enviar una orden
    // Leer/actualizar: cocina y admin necesitan acceso
    // Borrar: nunca desde el cliente (los pedidos son registro historico)
    match /pedidos/{pedidoId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ── CONTADORES (folios diarios) ──
    // Necesario para el numero secuencial de orden #001, #002...
    match /contadores/{contadorId} {
      allow read: if true;
      allow write: if true;
    }

    // ── USUARIOS (cuentas de cliente con email+contraseña, Firebase Auth) ──
    // Cada cliente autenticado solo puede leer/escribir SU PROPIO documento
    // (usuarioId == su uid de Firebase Auth). Aqui viven sus privilegios
    // (rol: 'cliente' por defecto, activo: true) — nunca se auto-asignan admin.
    match /usuarios/{usuarioId} {
      allow read:  if request.auth != null && request.auth.uid == usuarioId;
      allow create: if request.auth != null && request.auth.uid == usuarioId
                    && request.resource.data.rol == 'cliente';
      allow update: if request.auth != null && request.auth.uid == usuarioId
                    && request.resource.data.rol == resource.data.rol; // no puede cambiarse su propio rol
      allow delete: if false;
    }

    // ── TURNOS DE CAJA ──
    // Solo autenticados (corte de caja)
    match /turnos_caja/{turnoId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── CONFIGURACION (impuestos, propinas, etc) ──
    match /configuracion/{configId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── INVENTARIO ──
    match /inventario/{itemId} {
      allow read:  if true;
      allow write: if true;
    }

    // ── EMPLEADOS ──
    // El login por PIN necesita LEER sin auth (fallback sin Firebase Auth).
    // Escritura (crear/editar/borrar empleados y sus PINs) ahora requiere
    // sesion real de Firebase Auth (gerente/admin logueado via auth.html).
    // Antes cualquiera podia reescribir PINs/roles sin login — ya se cerro.
    match /empleados/{empleadoId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── CLIENTES (login rapido por telefono, sin Firebase Auth) ──
    // Se queda publico a proposito: el login por telefono es "demo" y no
    // tiene una identidad verificable por el servidor (no hay request.auth).
    // Para privacidad real usar la cuenta con email+contraseña (usuarios/).
    match /clientes/{clienteId} {
      allow read:  if true;
      allow write: if true;
    }

    // Todo lo demas: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
